{
  "ReverseProxy": {
    "Routes": {
      "basket-route": {
        "ClusterId": "basket-cluster",
        "Match": {
          "Path": "{version:regex(^[0-9]+$)}/baskets/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/{version}/baskets/{**catch-all}" } ]
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "{version:regex(^[0-9]+$)}/catalogs/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/{version}/catalogs/{**catch-all}" } ]
      },
      "discount-route": {
        "ClusterId": "discount-cluster",
        "Match": {
          "Path": "{version:regex(^[0-9]+$)}/discounts/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/{version}/discounts/{**catch-all}" } ]
      },
      "file-route": {
        "ClusterId": "file-cluster",
        "Match": {
          "Path": "{version:regex(^[0-9]+$)}/files/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/{version}/files/{**catch-all}" } ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "{version:regex(^[0-9]+$)}/orders/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/{version}/orders/{**catch-all}" } ]
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "{version:regex(^[0-9]+$)}/payments/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/{version}/payments/{**catch-all}" } ]
      }
    },
    "Clusters": {
      "basket-cluster": {
        "Destinations": {
          "basket-destination": {
            "Address": "http://localhost:5076/"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "catalog-destination": {
            "Address": "http://localhost:5132/"
          }
        }
      },
      "discount-cluster": {
        "Destinations": {
          "discount-destination": {
            "Address": "http://localhost:5212/"
          }
        }
      },
      "file-cluster": {
        "Destinations": {
          "file-destination": {
            "Address": "http://localhost:5152/"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-destination": {
            "Address": "http://localhost:5157/"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-destination": {
            "Address": "http://localhost:5292/"
          }
        }
      }
    },
    "IdentityOption": {
      "Address": "http://localhost:8080/realms/udemyTenant",
      "Issuer": "http://localhost:8080/realms/udemyTenant",
      "Audience": "gateway.api"
    },
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  }
}